### RAG - Ask about company policy
POST {{baseurl}}/api/rag/chat
Content-Type: application/json

{
  "question": "How many days of paid leave do employees get at TechCorp?",
  "sessionId": "rag-test"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Answer mentions 30 days", function() {
        var answer = response.body.answer.toLowerCase();
        client.assert(answer.includes("30"), "Answer should mention 30 days paid leave");
    });
%}

###

### RAG - Ask about product roadmap
POST {{baseurl}}/api/rag/chat
Content-Type: application/json

{
  "question": "What is TechCorp planning to launch in 2026?",
  "sessionId": "rag-test"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Answer mentions roadmap items", function() {
        var answer = response.body.answer.toLowerCase();
        var hasMcp = answer.includes("mcp");
        var hasAgent = answer.includes("agent");
        var hasRag = answer.includes("rag");
        client.assert(hasMcp || hasAgent || hasRag, "Answer should mention roadmap items");
    });
%}

###

### RAG - Ask about employee count
POST {{baseurl}}/api/rag/chat
Content-Type: application/json

{
  "question": "How many employees does TechCorp have and where are the offices?",
  "sessionId": "rag-test"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Answer mentions employee count and offices", function() {
        var answer = response.body.answer.toLowerCase();
        client.assert(answer.includes("85") || answer.includes("coimbatore"),
            "Answer should mention 85 employees or Coimbatore office");
    });
%}

