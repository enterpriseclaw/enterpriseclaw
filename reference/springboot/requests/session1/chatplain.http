### Chat Plain - Ask a Question
POST {{baseurl}}/api/chatplain
Content-Type: application/json

{
  "question": "What is the capital of France?",
  "sessionId": "test-session-123"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
    
    client.test("Response has valid structure", function() {
        var body = response.body;
        client.assert(body !== null && body !== undefined, "Response body is empty");
        client.assert(body.question !== undefined, "Response missing 'question' field");
        client.assert(body.answer !== undefined, "Response missing 'answer' field");
    });
    
    client.test("Response fields are not empty", function() {
        var body = response.body;
        client.assert(body.question.length > 0, "Question field is empty");
        client.assert(body.answer.length > 0, "Answer field is empty");
    });
    
    client.test("Question matches request", function() {
        var body = response.body;
        client.assert(body.question === "What is the capital of France?", "Question doesn't match request");
    });
%}

