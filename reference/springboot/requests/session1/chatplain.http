### Chat Plain - Programming Question
POST {{baseurl}}/api/chatplain
Content-Type: application/json

{
  "question": "Explain what is Spring Boot in one sentence",
  "sessionId": "test-session-456"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });
    
    client.test("Response is not empty", function() {
        var body = response.body;
        client.assert(body !== null && body !== undefined, "Response body is empty");
        client.assert(body.answer.length > 0, "Answer is empty");
    });
%}

