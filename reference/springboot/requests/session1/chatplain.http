### Structured Output - Book Recommendation
GET {{baseurl}}/api/recommend?genre=science-fiction

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response has structured fields", function() {
        var body = response.body;
        client.assert(body.title !== undefined && body.title.length > 0, "Missing or empty 'title'");
        client.assert(body.author !== undefined && body.author.length > 0, "Missing or empty 'author'");
        client.assert(body.reason !== undefined && body.reason.length > 0, "Missing or empty 'reason'");
    });
%}

