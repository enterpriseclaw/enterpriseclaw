###

### Chat with Memory - First message
POST {{baseurl}}/api/chatmemory
Content-Type: application/json

{
  "question": "My name is Muthu and I am from Coimbatore",
  "sessionId": "memory-session-1"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response is not empty", function() {
        client.assert(response.body.answer.length > 0, "Answer is empty");
    });
%}

###

### Chat with Memory - Second message (should remember name)
POST {{baseurl}}/api/chatmemory
Content-Type: application/json

{
  "question": "What is my name and where am I from?",
  "sessionId": "memory-session-1"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response remembers context", function() {
        var answer = response.body.answer.toLowerCase();
        client.assert(answer.includes("muthu"), "Response should remember the name 'Muthu'");
    });
%}

###

### Chat without Memory - Same session ID but different endpoint (should NOT remember)
POST {{baseurl}}/api/chat
Content-Type: application/json

{
  "question": "What is my name?",
  "sessionId": "memory-session-1"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response does NOT remember (no memory)", function() {
        var answer = response.body.answer.toLowerCase();
        client.assert(!answer.includes("muthu"), "Plain chat should NOT remember the name");
    });
%}

###

### Full ChatResponse - See metadata, usage tokens, model info
POST {{baseurl}}/api/chatresponse
Content-Type: application/json

{
  "question": "What is Java?",
  "sessionId": "response-test"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response has metadata with usage info", function() {
        var body = response.body;
        client.assert(body.metadata !== undefined, "Missing 'metadata'");
        var usage = body.metadata.usage;
        client.assert(usage !== undefined, "Missing 'usage' in metadata");
        client.assert(usage.promptTokens > 0, "promptTokens should be > 0");
        client.assert(usage.completionTokens > 0, "completionTokens should be > 0");
        client.assert(usage.totalTokens > 0, "totalTokens should be > 0");
    });

    client.test("Response has generation result", function() {
        var results = response.body.results;
        client.assert(results !== undefined && results.length > 0, "Missing 'results'");
        client.assert(results[0].output !== undefined, "Missing 'output' in first result");
        client.assert(results[0].output.text.length > 0, "Output text is empty");
    });
%}

