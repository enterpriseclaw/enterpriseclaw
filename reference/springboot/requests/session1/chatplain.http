        client.assert(body.title !== undefined, "Missing 'title'");
        client.assert(body.author !== undefined, "Missing 'author'");
        client.assert(body.reason !== undefined, "Missing 'reason'");
    });
%}

###

### The Limitation - Ask about YOUR data (LLM can't answer)
POST {{baseurl}}/api/chatplain
Content-Type: application/json

{
  "question": "What products are in our inventory right now?",
  "sessionId": "limitation-test"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("LLM admits it cannot access inventory", function() {
        var answer = response.body.answer.toLowerCase();
        var admitsLimitation = answer.includes("don't have access") ||
                               answer.includes("cannot access") ||
                               answer.includes("no access") ||
                               answer.includes("don't have information") ||
                               answer.includes("unable to") ||
                               answer.includes("i don't know");
        client.assert(admitsLimitation, "LLM should admit it can't access live inventory data");
    });
%}

