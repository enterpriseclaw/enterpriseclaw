### Tool Calling - Ask about products (calls getProducts)
POST {{baseurl}}/api/tools/chat
Content-Type: application/json

{
  "question": "What products do you have in stock?",
  "sessionId": "tools-test-1"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response mentions products", function() {
        var answer = response.body.answer.toLowerCase();
        client.assert(answer.includes("spring ai") || answer.includes("java") || answer.includes("product"),
            "Response should mention products from inventory");
    });
%}

###

### Tool Calling - Search for a specific product (calls searchProduct)
POST {{baseurl}}/api/tools/chat
Content-Type: application/json

{
  "question": "Do you have anything about Kubernetes?",
  "sessionId": "tools-test-2"
}

> {%
    client.test("Request executed successfully", function() {
        client.assert(response.status === 200, "Response status is not 200");
    });

    client.test("Response mentions Kubernetes", function() {
        var answer = response.body.answer.toLowerCase();
        client.assert(answer.includes("kubernetes"), "Response should mention Kubernetes product");
    });
%}

