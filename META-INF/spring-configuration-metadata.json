{
  "groups": [
    {
      "name": "spring.test.mockmvc",
      "type": "org.springframework.boot.webmvc.test.autoconfigure.SpringBootMockMvcBuilderCustomizer",
      "sourceType": "org.springframework.boot.webmvc.test.autoconfigure.MockMvcConfiguration",
      "sourceMethod": "springBootMockMvcBuilderCustomizer()"
    }
  ],
  "properties": [
    {
      "name": "spring.test.mockmvc.add-filters",
      "type": "java.lang.Boolean",
      "description": "Whether to add servlet filters.",
      "sourceType": "org.springframework.boot.webmvc.test.autoconfigure.SpringBootMockMvcBuilderCustomizer",
      "defaultValue": true
    },
    {
      "name": "spring.test.mockmvc.htmlunit.url",
      "type": "java.lang.Boolean",
      "description": "URL to use when HtmlUnit expands relative paths.",
      "defaultValue": "http:\/\/localhost"
    },
    {
      "name": "spring.test.mockmvc.htmlunit.webclient.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether HTMLUnit's WebClient should be auto-configured when it's on the classpath.",
      "defaultValue": true
    },
    {
      "name": "spring.test.mockmvc.htmlunit.webdriver.enabled",
      "type": "java.lang.Boolean",
      "description": "Whether Selenium's WebDriver should be auto-configured when it's on the classpath.",
      "defaultValue": true
    },
    {
      "name": "spring.test.mockmvc.print",
      "type": "org.springframework.boot.webmvc.test.autoconfigure.MockMvcPrint",
      "description": "MVC Print option.",
      "sourceType": "org.springframework.boot.webmvc.test.autoconfigure.SpringBootMockMvcBuilderCustomizer",
      "defaultValue": "default"
    },
    {
      "name": "spring.test.mockmvc.print-only-on-failure",
      "type": "java.lang.Boolean",
      "description": "Whether to only print failed exchanges.",
      "sourceType": "org.springframework.boot.webmvc.test.autoconfigure.SpringBootMockMvcBuilderCustomizer",
      "defaultValue": true
    },
    {
      "name": "spring.test.mockmvc.webclient.enabled",
      "type": "java.lang.Boolean",
      "deprecated": true,
      "deprecation": {
        "level": "error",
        "replacement": "spring.test.mockmvc.htmlunit.webclient.enabled",
        "since": "4.0.0"
      }
    },
    {
      "name": "spring.test.mockmvc.webdriver.enabled",
      "type": "java.lang.Boolean",
      "deprecated": true,
      "deprecation": {
        "level": "error",
        "replacement": "spring.test.mockmvc.htmlunit.webdriver.enabled",
        "since": "4.0.0"
      }
    }
  ],
